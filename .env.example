# Copy to .env and customize.

# Backend
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# Default (development): SQLite stored on disk
DATABASE_URL=sqlite:///./backend/storage/peoplesense.db
# Production example:
# DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/peoplesense

# Detection
YOLO_MODEL_PATH=./yolov8n.pt
YOLO_CONFIDENCE=0.35
YOLO_IOU=0.5

# Frontend dev proxy
VITE_API_TARGET=http://localhost:8000
